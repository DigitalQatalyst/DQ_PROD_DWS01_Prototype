# DWS.01 BFF configuration.
# These variables are read from the repository-root .env (preferred) or a
# server-local .env. The root .env already contains provisioned values; this
# file documents the contract. Never commit real secrets.

# On Vercel (serverless), set these as Project -> Settings -> Environment
# Variables instead of a .env file. The BFF runs as the /api function; the
# frontend and BFF are same-origin via the rewrites in vercel.json.

# --- BFF / session ---
BFF_PORT=4000
# Local dev: the Vite dev origin. On Vercel: your deployment URL, e.g.
# https://<your-project>.vercel.app (used for post-login redirects).
FRONTEND_ORIGIN=http://localhost:5173
SESSION_COOKIE_NAME=dws_session
SESSION_SECRET=change-me-to-a-long-random-string
SESSION_TTL_MINUTES=480

# Set true to bypass Entra and create a local mock session (offline dev only).
AUTH_DEV_MOCK_ENABLED=false

# --- Microsoft Entra ID (app registration) ---
ENTRA_TENANT_ID=00000000-0000-0000-0000-000000000000
ENTRA_CLIENT_ID=00000000-0000-0000-0000-000000000000
ENTRA_CLIENT_SECRET=your-client-secret
# Must exactly match a Redirect URI registered on the Entra app (Web platform).
# Local dev: http://localhost:4000/auth/callback
# On Vercel: https://<your-project>.vercel.app/auth/callback  <-- use the Vercel
# domain (NOT a separate BFF host). The PKCE/state session cookie is first-party
# to the Vercel domain, so Entra must redirect the browser back to that domain.
ENTRA_REDIRECT_URI=http://localhost:4000/auth/callback
ENTRA_SCOPES=openid,profile,email

# --- Canonical IAM + audit store (ADR-DWS01-IAM-012) ---
# Supabase/Postgres connection string. When omitted, the BFF uses an in-memory
# seed directory (prototype validation only).
# REQUIRED on Vercel: serverless functions are stateless, so sessions are stored
# in Postgres (connect-pg-simple, table "user_sessions"). Without DATABASE_URL,
# sessions fall back to an in-memory store that does NOT survive between
# serverless invocations, so login will not stick. Prefer a pooled connection
# string (e.g. Supabase's pooler / pgbouncer, port 6543) for serverless.
# DATABASE_URL=postgresql://user:password@host:5432/postgres
