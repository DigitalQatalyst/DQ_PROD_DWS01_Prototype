BFF_PORT=4000
FRONTEND_ORIGIN=http://localhost:5173
SESSION_COOKIE_NAME=dws_session
SESSION_SECRET=replace-with-a-long-random-secret
SESSION_TTL_MINUTES=480

# Development fallback only. Set to false when Entra config is present.
AUTH_DEV_MOCK_ENABLED=true

# Microsoft Entra ID app registration
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=
ENTRA_CLIENT_SECRET=
ENTRA_REDIRECT_URI=http://localhost:4000/auth/callback
ENTRA_SCOPES=openid,profile,email
